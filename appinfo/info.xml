<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>openklant</id>
    <name>OpenKlant</name>
    <summary>OpenKlant customer interaction management for Nextcloud</summary>
    <description><![CDATA[OpenKlant Integration for Nextcloud

Integrate OpenKlant customer interaction registry with your Nextcloud instance.

- Customer contact management from Nextcloud
- Klantinteracties API integration
- Link customer interactions with cases and documents
- Common Ground / ZGW API compliant
- Free and open source under EUPL

This is an ExApp (External Application) - Nextcloud will automatically manage the OpenKlant container.

**Note:** OpenKlant requires PostgreSQL database for full functionality.
    ]]></description>
    <version>0.1.1-unstable.2</version>
    <licence>agpl</licence>
    <author mail="info@conduction.nl" homepage="https://www.conduction.nl/">Conduction</author>
    <category>office</category>
    <category>social</category>
    <website>https://github.com/ConductionNL/OpenKlant</website>
    <bugs>https://github.com/ConductionNL/OpenKlant/issues</bugs>
    <repository>https://github.com/ConductionNL/OpenKlant</repository>

    <screenshot>https://raw.githubusercontent.com/ConductionNL/openklant/main/img/screenshot.png</screenshot>

    <documentation>
        <user>https://github.com/maykinmedia/open-klant</user>
        <admin>https://github.com/maykinmedia/open-klant</admin>
        <developer>https://github.com/maykinmedia/open-klant</developer>
    </documentation>

    <dependencies>
        <nextcloud min-version="30" max-version="33"/>
    </dependencies>

    <external-app>
        <docker-install>
            <registry>localhost:5000</registry>
            <image>openklant-exapp</image>
            <image-tag>test</image-tag>
        </docker-install>

        <routes>
            <route>
                <url>.*</url>
                <verb>GET,POST,PUT,DELETE,PATCH,OPTIONS</verb>
                <access_level>USER</access_level>
                <headers_to_exclude>[]</headers_to_exclude>
            </route>
        </routes>

        <environment-variables>
            <variable>
                <name>DB_HOST</name>
                <display-name>Database Host</display-name>
                <description>PostgreSQL database host</description>
            </variable>
            <variable>
                <name>DB_NAME</name>
                <display-name>Database Name</display-name>
                <description>PostgreSQL database name</description>
            </variable>
            <variable>
                <name>DB_USER</name>
                <display-name>Database User</display-name>
                <description>PostgreSQL database user</description>
            </variable>
            <variable>
                <name>DB_PASSWORD</name>
                <display-name>Database Password</display-name>
                <description>PostgreSQL database password</description>
            </variable>
            <variable>
                <name>SECRET_KEY</name>
                <display-name>Secret Key</display-name>
                <description>Django secret key (generate a random string)</description>
            </variable>
            <variable>
                <name>ALLOWED_HOSTS</name>
                <display-name>Allowed Hosts</display-name>
                <description>Comma-separated list of allowed hostnames (use * for development)</description>
            </variable>
            <variable>
                <name>KEYCLOAK_URL</name>
                <display-name>Keycloak URL</display-name>
                <description>Keycloak server URL for SSO (e.g., http://keycloak:8080)</description>
            </variable>
            <variable>
                <name>KEYCLOAK_REALM</name>
                <display-name>Keycloak Realm</display-name>
                <description>Keycloak realm name (default: commonground)</description>
            </variable>
            <variable>
                <name>KEYCLOAK_CLIENT_ID</name>
                <display-name>Keycloak Client ID</display-name>
                <description>OIDC client ID for this app (default: openklant)</description>
            </variable>
            <variable>
                <name>KEYCLOAK_CLIENT_SECRET</name>
                <display-name>Keycloak Client Secret</display-name>
                <description>OIDC client secret for this app</description>
            </variable>
        </environment-variables>
    </external-app>
</info>
